@page "/present-groups"
@rendermode InteractiveServer

<h3>Present Groups</h3>

@if (PresentGroupModels == null)
{
    <p>Loading...</p>
}
else
{
    <a class="btn btn-primary" href="/present-groups/create">Create New Present Group</a>
    <ul>
        @foreach (var group in PresentGroupModels)
        {
            <li>@group.Name</li>
            <li>
                <a class="btn btn-secondary" href="/present-groups/update/@group.Id">Update</a>
                <button class="btn btn-danger" @onclick="() => { DeleteId = group.Id; AppModal.OpenModal(); }">Delete</button>
            </li>
        }
    </ul>
}

<AppModal @ref="AppModal">
    <Title>Notification</Title>
    <Body>
        Are you sure you want to delete this present group?
    </Body>
    <Footer>
        <button type="button" class="btn btn-primary" style="width:80px" @onclick="HandleDelete">Yes</button>
        <button type="button" class="btn btn-secondary" data-dismiss="modal" @onclick="() => AppModal.CloseModal()">Cancel</button>
    </Footer>
</AppModal>
