@rendermode InteractiveServer
@using SantaClauzer.Web.Services
@using Microsoft.AspNetCore.Components.Routing
@inject NotificationState NotificationState
@inject NavigationManager NavigationManager

@if (currentToast is not null)
{
    <div class="position-fixed top-0 end-0 p-3" style="z-index: 1055;">
        <div class="alert @GetAlertClass(currentToast.Type) alert-dismissible fade show" role="alert" style="min-width: 300px;">
            <strong>@currentToast.Title</strong>
            <div>@currentToast.Message</div>
            <button type="button" class="btn-close" @onclick="DismissToast" aria-label="Close"></button>
        </div>
    </div>
}

@code {
    private PendingToast? currentToast;
    private CancellationTokenSource? _dismissCts;
    // Auto-dismiss timeout in milliseconds (change as desired)
    private readonly int _autoDismissMs = 5000;

    protected override void OnInitialized()
    {
        NotificationState.ToastAdded += OnToastAdded;
        NavigationManager.LocationChanged += OnLocationChanged;

        // show any pending toast already set before this component initialized
        var p = NotificationState.Consume();
        if (p is not null)
            ShowToast(p);
    }

    private void OnToastAdded(PendingToast p)
    {
        ShowToast(p);
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        var p = NotificationState.Consume();
        if (p is not null)
        {
            ShowToast(p);
        }
    }

    private void ShowToast(PendingToast p)
    {
        // Cancel previous dismiss timer
        _dismissCts?.Cancel();
        _dismissCts?.Dispose();

        currentToast = p;
        InvokeAsync(StateHasChanged);

        // Start new auto-dismiss timer
        _dismissCts = new CancellationTokenSource();
        _ = AutoDismissAsync(_dismissCts.Token);
    }

    private async Task AutoDismissAsync(CancellationToken token)
    {
        try
        {
            await Task.Delay(_autoDismissMs, token);
            if (!token.IsCancellationRequested)
            {
                currentToast = null;
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (TaskCanceledException)
        {
            // expected when a new toast arrives or user dismisses it
        }
    }

    private void DismissToast()
    {
        // user dismissed; cancel timer and clear
        _dismissCts?.Cancel();
        _dismissCts?.Dispose();
        _dismissCts = null;
        currentToast = null;
        InvokeAsync(StateHasChanged);
    }

    private string GetAlertClass(NotificationType t) => t switch
    {
        NotificationType.Success => "alert-success",
        NotificationType.Error => "alert-danger",
        NotificationType.Warning => "alert-warning",
        _ => "alert-info"
    };

    public void Dispose()
    {
        NotificationState.ToastAdded -= OnToastAdded;
        NavigationManager.LocationChanged -= OnLocationChanged;
        _dismissCts?.Cancel();
        _dismissCts?.Dispose();
    }
}