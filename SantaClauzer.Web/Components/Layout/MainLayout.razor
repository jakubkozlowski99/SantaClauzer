@inherits LayoutComponentBase
@using SantaClauzer.Web.Services
@using Microsoft.AspNetCore.Components.Routing
@inject NotificationState NotificationState
@inject NavigationManager NavigationManager

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            <a href="https://learn.microsoft.com/aspnet/core/" target="_blank">About</a>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<!-- interactive host component renders inside layout and handles toast UI -->
<ToastHost />

@code {
    // layout no longer needs to be interactive; toast handling lives in ToastHost
}
